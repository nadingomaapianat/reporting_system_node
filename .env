# Database Configuration
DB_HOST=206.189.57.0
DB_PORT=1433
# DB_Domain=ADIBEG (not needed for SQL auth)
DB_USERNAME=SA
DB_PASSWORD=Nothing_159
DB_NAME=NEWDCC-V4-UAT
DASHBOARD_DEFAULT_LIMIT=10
REPORTS_EMPTY_FUNCTIONS_SEE_ALL=true

# Database Connection Timeouts
DB_REQUEST_TIMEOUT=60000
DB_CONNECT_TIMEOUT=60000

# Database Connection Pool Settings
DB_POOL_MAX=200
DB_POOL_MIN=20
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=30000
DB_POOL_EVICT=1000

# Application Settings
NODE_ENV=development
PORT=3002

# When user has no function assignments in UserFunction table, they see no data (0 rows).
# Set to true to let them see all KRI/risk/control data (e.g. until UserFunction is populated or main backend sends group_name).
REPORTS_EMPTY_FUNCTIONS_SEE_ALL=true

# Open mode: when true, the reporting backend skips JWT/CSRF/IET checks and treats every
# request as a super-admin. Use ONLY when the iframe is embedded by a trusted parent
# origin (controlled via FRAME_ANCESTORS / CORS below).
REPORTING_OPEN_MODE=true
OPEN_MODE_USER_ID=open-mode-user

# Admin users: main backend can send group_name='super_admin_' or role='admin' or is_admin=true in entry/validate response.
# Or list user IDs that should see all functions (comma-separated). These users get "All Functions" in filter and see all data when none selected.
# REPORTING_SUPER_ADMIN_USER_IDS=user-id-1,user-id-2

# JWT Configuration
JWT_SECRET=GRC_ADIB_2025
SUPER_ADMIN_USERNAME=grcsvc

# LDAP Configuration
LDAP_ID_SMTP=10.240.5.217
LDAP_ID_PORT=25
LDAP_PASS=P@ssw0rd
LDAP_IP=10.240.5.204
LDAP_URL=ldaps://dc01.adib.co.eg
LDAP_BIND_DN_DOMAIN=@adib.co.eg
LDAP_BIND_DN_USERNAME=GRCSVC@adib.co.eg
LDAP_USERNAME_ATTRIBUTE=sAMAccountName
LDAP_SEARCH_FILTER=sAMAccountName
LDAP_SEARCH_BASE=OU=GRC,DC=adib,DC=co,DC=eg
LDAP_SEARCH_BASE_DC=adib
LDAP_SEARCH_BASE_CO=co
LDAP_SEARCH_BASE_EG=eg
LDAP_PASSWORD=P@ssw0rd
LDAP_SEARCH_OU=OU=GRC,DC=adib,DC=co,DC=eg
LDAP_ATTRIBUTES=cn,mail,sAMAccountName,title,memberOf,userPrincipalName
LDAP_OPERATION_TIMEOUT=30000
LDAP_TIMEOUT=10000
LDAP_CONNECT_TIMEOUT=5000
LDAP_IDLE_TIMEOUT=30000
LDAP_RECONNECT=true
LDAP_MAX_RETRIES=1
LDAP_RETRY_DELAY=2000

# Email Configuration
