# Frontend URLs
FRONTEND_URL=https://ubm.comply.now


# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS Configuration – list every origin that calls the reporting backend (frontend + python + parent app)
CORS_ORIGINS=https://reporting-ubm-system-frontend.comply.now,https://backendnode-ubm-reporting.comply.now,https://reporting-ubm-system-python.comply.now,https://ubm.comply.now,https://dcc-ubm.comply.now
ALLOWED_ORIGINS=https://reporting-ubm-system-frontend.comply.now,https://backendnode-ubm-reporting.comply.now,https://reporting-ubm-system-python.comply.now,https://ubm.comply.now,https://dcc-ubm.comply.now
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Requested-With,x-csrf-token
CORS_EXPOSED_HEADERS=Content-Range,X-Content-Range
CORS_CREDENTIALS=true

# Iframe / parent app origins (clickjacking protection: who is allowed to embed the iframe)
FRAME_ANCESTORS=https://ubm.comply.now,https://dcc-ubm.comply.now,https://reporting-ubm-system-frontend.comply.now
IFRAME_MAIN_ORIGIN=https://ubm.comply.now
MAIN_APP_ORIGIN=https://ubm.comply.now

# Public URLs for the reporting stack
MAIN_BACKEND_URL=https://backend-ubm-compliance.comply.now
NEXT_PUBLIC_REPORTING_FRONTEND_URL=https://reporting-ubm-system-frontend.comply.now
REPORTING_FRONTEND_URL=https://reporting-ubm-system-frontend.comply.now
NODE_PUBLIC_URL=https://backendnode-ubm-reporting.comply.now

# Allowed origins for entry-token endpoint (only used when REPORTING_OPEN_MODE=false)
ENTRY_TOKEN_ALLOWED_ORIGINS=https://ubm.comply.now,https://reporting-ubm-system-frontend.comply.now
LOGOUT_ALLOWED_ORIGINS=https://ubm.comply.now,https://reporting-ubm-system-frontend.comply.now,https://backendnode-ubm-reporting.comply.now
