# Copy to .env and adjust. Reporting node IET exchange calls:
#   POST {MAIN_BACKEND_URL}{MAIN_BACKEND_ENTRY_VALIDATE_PATH}
# That response must include a non-empty permissions[] (same shape as main-app login JWT) or the reporting cookie JWT will only contain { id }.

MAIN_BACKEND_URL=https://your-main-api.example.com
MAIN_BACKEND_ENTRY_VALIDATE_PATH=/entry/validate

# Origin header sent to main backend when exchanging IET (must match main backend IFRAME_MAIN_ORIGIN allowlist).
IFRAME_MAIN_ORIGIN=https://your-main-frontend.example.com

JWT_SECRET=change-me
